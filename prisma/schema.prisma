generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Template {
  id        String          @id @default(cuid())
  name      String
  category  String
  svgPath   String
  fields    String          // legacy JSON string: [{ id, label, defaultValue }]
  thumbnail String?
  printColorProfileMode String?
  adobeWorkingCmykPreset String?
  customIccPath String?
  parentId  String?         // legacy variant structure, retained for compatibility
  parent    Template?       @relation("TemplateVariants", fields: [parentId], references: [id])
  variants  Template[]      @relation("TemplateVariants")
  createdAt DateTime        @default(now())
  projects  Project[]
  sheets    TemplateSheet[]
}

model TemplateSheet {
  id         String   @id @default(cuid())
  templateId String
  name       String
  order      Int
  svgPath    String
  fields     String
  width      Float?
  height     Float?
  unit       String?
  widthPx    Float?
  heightPx   Float?
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, order])
}

model Project {
  id         String   @id @default(cuid())
  name       String
  values     String   // JSON string: nested sheet values, legacy flat values allowed
  sheetSnapshot String? // JSON string: project-local sheet snapshots
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  templateId String
  user       User     @relation(fields: [userId], references: [id])
  template   Template @relation(fields: [templateId], references: [id])
}
